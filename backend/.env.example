APP_NAME="Ijazah Blockchain - Universitas Subang"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_FRONTEND_URL=http://localhost:3000

LOG_CHANNEL=stack
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=ijazah_blockchain
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

SANCTUM_STATEFUL_DOMAINS=localhost:3000,127.0.0.1:3000
SESSION_DOMAIN=localhost

# ============================================
# BLOCKCHAIN CONFIGURATION - SEPOLIA TESTNET
# ============================================
# Network: Sepolia Testnet (BUKAN Mainnet!)
# Chain ID: 11155111
# Dapatkan SepoliaETH gratis dari: https://sepoliafaucet.com

# Mock Mode: true = tanpa koneksi blockchain real (untuk development)
BLOCKCHAIN_MOCK_MODE=true

# RPC Provider (pilih salah satu):
# Infura:  https://sepolia.infura.io/v3/YOUR_PROJECT_ID
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
# Public:  https://rpc.sepolia.org
# Cloudflare: https://sepolia.gateway.tenderly.co
BLOCKCHAIN_RPC_URL=https://rpc.sepolia.org
BLOCKCHAIN_WS_URL=wss://rpc.sepolia.org/ws
BLOCKCHAIN_CHAIN_ID=11155111

# Smart Contract (deploy IjazahStorage.sol ke Sepolia)
BLOCKCHAIN_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Admin Wallet (harus ada SepoliaETH dari faucet untuk gas)
BLOCKCHAIN_ADMIN_ADDRESS=0x0000000000000000000000000000000000000000
BLOCKCHAIN_ADMIN_PRIVATE_KEY=

# Block Explorer
BLOCKCHAIN_EXPLORER_URL=https://sepolia.etherscan.io

# Gas Configuration (Sepolia Testnet)
BLOCKCHAIN_GAS_LIMIT=3000000
BLOCKCHAIN_GAS_PRICE_GWEI=20

# QR Code
QR_CODE_SIZE=300
QR_CODE_MARGIN=10
